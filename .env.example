# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RAPIDAPI_KEY: Optional server-side fallback pool for TikTok metrics.
# You can provide one key or many keys separated by commas / new lines.
# Example:
# RAPIDAPI_KEY="key_1,key_2,key_3"
RAPIDAPI_KEY="YOUR_RAPIDAPI_KEY"

# RAPIDAPI_COOLDOWN_MS: Cooldown applied when a key returns 429 / quota errors.
# Default is 900000 (15 minutes).
# RAPIDAPI_COOLDOWN_MS="900000"

# SCRAPE_CACHE_TTL_MS: Short-term cache for successful profile scrape responses.
# Default is 21600000 (6 hours).
# SCRAPE_CACHE_TTL_MS="21600000"

# ENABLE_SERVERLESS_PUPPETEER: Optional. Set to "true" only if your serverless
# runtime is prepared to run Puppeteer fallback. By default Netlify/Vercel paths
# should rely on RapidAPI key rotation instead of launching a browser.
# ENABLE_SERVERLESS_PUPPETEER="true"
